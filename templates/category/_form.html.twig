{{ form_start(form) }}
    {{ form_widget(form) }}
    <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
    {% if show_delete %}
        <button class="btn btn-secondary" type="button" onclick="SubmitDelete()">Delete</button>
    {% endif %}
{{ form_end(form) }}
{% if show_delete %}
    {{ include('category/_delete_form.html.twig') }}
{% endif %}
<script>
function SubmitDelete()
{
    document.getElementById("delete-category").requestSubmit();
}
</script>