{% extends 'base.html.twig' %}

{% block title %}Category{% endblock %}

{% block body %}
    <div class="bg-secondary mb-2 px-2">
        <a class="text-white" href="{{ path('app_category_index') }}">Categories</a>
        <span class="text-white">&gt; New</span>
    </div>

    <div class="row text-center mx-5">
        <div class="col-md-4 mx-auto">
            <div class="card border-dark">
                <div class="card-head">
                    <h1 class="card-title">Category</h1>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tbody>
                            <tr>
                                <th class="table-secondary text-end">Id</th>
                                <td class="text-start">{{ category.id }}</td>
                            </tr>
                            <tr>
                                <th class="table-secondary text-end">Name</th>
                                <td class="text-start">{{ category.Name }}</td>
                            </tr>
                            <tr>
                                <th class="table-secondary text-end">Description</th>
                                <td class="text-start">{{ category.Description }}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer">
                    <a class="btn btn-primary" href="{{ path('app_category_edit', {'id': category.id}) }}">Edit</a>
                    {{ include('category/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
