{% extends 'base.html.twig' %}

{% block title %}Candidate index{% endblock %}

{% block body %}
    <div class="bg-secondary mb-2 px-2  d-flex">
        <span class="active">
            <a class="text-white active" href="{{ path('app_candidate_index') }}">Listing</a>
        </span>
        <span class="mx-1">&gt;</span>
        <span>
            <a class="text-white active" href="{{ path('app_candidate_cards') }}">Roster</a>
        </span>
        <span class="flex-grow-1 text-end last">
            <a class="btn btn-success btn-sm" href="{{ path('app_candidate_new') }}">New Babe</a>
        </span>
    </div>

    {# Search form for Category & Gender (defaults come from user prefs) #}
    <div class="mx-3 mb-3 p-2" style="background-color: #d6d6d6">
        <form method="get" action="{{ path('app_candidate_index') }}" class="row g-2 align-items-end">
            <div class="col-auto me-2">
                <label for="category" class="form-label small mb-1">Category</label>
                <select id="category" name="category" class="form-select">
                    <option value="">Any</option>
                    {% for cat in categories %}
                        <option value="{{ cat.name }}" {% if cat.name == selectedCategory %}selected{% endif %}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-auto me-2">
                <label for="gender" class="form-label small mb-1">Gender</label>
                <select id="gender" name="gender" class="form-select">
                    <option value="">Any</option>
                    {% for g in genderOptions %}
                        <option value="{{ g }}" {% if g == selectedGender %}selected{% endif %}>{{ g }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Filter</button>
            </div>
        </form>
    </div>

    <h1>Candidate index</h1>

    <table class="table table-condensed table-striped">
        <thead>
            <tr>
                <th>Id<a href="#">{{ ux_icon('flowbite:caret-sort-solid') }}</a></th>
                <th>Name<a href="#">{{ ux_icon('flowbite:caret-sort-solid') }}</a></th>
                <th>Category<a href="#">{{ ux_icon('flowbite:caret-sort-solid') }}</a></th>
                <th>Bio</th>
                <th>Gender<a href="#">{{ ux_icon('flowbite:caret-sort-solid') }}</a></th>
                <th>Married<a href="#">{{ ux_icon('flowbite:caret-sort-solid') }}</a></th>
                <th>Interests</th>
                <th>Lifestyle</th>
                <th>AdditionalInformation</th>
            </tr>
        </thead>
        <tbody>
        {% for candidate in candidates %}
            {% set gq = candidate.Name|replace({' ': '+'}) ~ '+' ~ candidate.Categories|map(c=>c.Name)|join('+')|replace({' ': '+'}) %}
            <tr>
                <td class="candidate-hs text-center">
                    <div class="fs-8 flex flex-column align-items-center">
                        <div>
                            {{ "%'03.10s"|format(candidate.id) }}
                        </div>
                        <div>
                            <a class="btn btn-sm btn-primary" title='View' href="{{ path('app_candidate_show', {'id': candidate.id}) }}">{{ ux_icon('lsicon:view-outline') }}</a>
                        </div>
                        <div>
                            <a class="btn btn-sm btn-info" title='Edit' href="{{ path('app_candidate_edit', {'id': candidate.id}) }}">{{ ux_icon('ic:baseline-edit') }}</a>
                        </div>
                        <div>
                            <form method="post" action="{{ path('app_candidate_img_search', {'id': candidate.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('img-search' ~ candidate.id) }}">
                                <button class="btn btn-sm btn-primary" type="submit" title="Find new Picture">{{ ux_icon('gravity-ui:binoculars') }}</button>
                            </form>
                        </div>
                    </div>
                </td>
                <td class="candidate-hs text-center">
                    <a href="https://www.google.com/search?q={{ gq }}" target="_blank">
                        <img src="{{ candidate.ImgUrl }}" class="thumbnail img-thumbnail mx-auto" />
                    </a>
                    <div class="text-center">{{ candidate.Name }}</div>
                </td>
                <td>{{ candidate.Categories|map(c=>c.Name)|join(' | ') }}</td>
                <td>
                    <div class="desc-short">
                        {{ candidate.Bio }}
                    </div>
                </td>
                <td>{{ candidate.Gender.value }}</td>
                <td>{{ candidate.Married ? 'Yes' : 'No' }}</td>
                <td>
                    <div class="desc-short">
                        {{ candidate.Interests }}
                    </div>
                </td>
                <td>
                    <div class="desc-short">
                       {{ candidate.Lifestyle}}
                    </div>
                </td>
                <td>
                    <div class="desc-short">
                        {{ candidate.AdditionalInformation}}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

<script>
function OrderBy(a,b,n) {
    if (n) return a-b;
    if (a < b) return -1;
    if (a > b) return 1;
    return 0;
}
var sort_table = function() {
    var $th = $(this).closest('th');
    $th.toggleClass('selected');
    var isSelected = $th.hasClass('selected');
    var isInput= $th.hasClass('input');
    var column = $th.index();
    var $table = $th.closest('table');
    var isNum= $table.find('tbody > tr').children('td').eq(column).hasClass('num');
    var rows = $table.find('tbody > tr').get();
    rows.sort(function(rowA,rowB) {
        var keyA = $(rowA).children('td').eq(column).text().toUpperCase();
        var keyB = $(rowB).children('td').eq(column).text().toUpperCase();
         if (isSelected) return OrderBy(keyA,keyB,isNum);
        return OrderBy(keyB,keyA,isNum);
    });

    $.each(rows, function(index,row) {
        $table.children('tbody').append(row);
    });
    return false;
};

$('th a').click(sort_table);
</script>

{% endblock %}