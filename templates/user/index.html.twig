{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}
    <div class="bg-secondary mb-2 px-2">
        <div class="text-end">
            <a class="btn btn-success btn-sm" href="{{ path('app_user_new') }}">Create new</a>
        </div>
    </div>
    <h1>User index</h1>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Nick Name</th>
                <th>Gender</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.FirstName }}</td>
                <td>{{ user.LastName }}</td>
                <td>{{ user.Email }}</td>
                <td>
                    {{ user.Roles|join(' | ') }}
                <td>{{ user.NickName }}</td>
                <td>{{ user.Gender.name }}</td>
                <td>
                    <a class="btn btn-sm btn-primary" title='View' href="{{ path('app_user_show', {'id': user.id}) }}">{{ ux_icon('lsicon:view-outline') }}</a>
                    <a class="btn btn-sm btn-info" title='Edit' href="{{ path('app_user_edit', {'id': user.id}) }}">{{ ux_icon('ic:baseline-edit') }}</a>
                    {{ include('user/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
