{% extends 'base.html.twig' %}

{% block title %}Smash or Pass{% endblock %}

{% block body %}
    <div class="bg-secondary mb-2 px-2">
        <a class="text-white" href="{{ path('app_welcome') }}">Smash or Pass</a>
        <span class="mx-1">&gt;</span>
        {% if candidate and candidate.id %}
            <a class="text-white"href="{{ path('app_candidate_edit', {'id': candidate.id}) }}">Edit Candidate</a>
           <span class="mx-1">&gt;</span>
        {% endif %}
        <span class="text-white">Vote</span>
    </div>

    {# Search form for Category & Gender (defaults come from user prefs) #}
    <div class="mx-3 mb-3 p-2" style="background-color: #d6d6d6">
        <form method="get" action="{{ path('app_welcome') }}" class="row g-2 align-items-end">
            <div class="col-auto me-2">
                <label for="category" class="form-label small mb-1">Category</label>
                <select id="category" name="category" class="form-select">
                    <option value="">Any</option>
                    {% for cat in categories %}
                        <option value="{{ cat.name }}" {% if cat.name == selectedCategory %}selected{% endif %}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-auto me-2">
                <label for="gender" class="form-label small mb-1">Gender</label>
                <select id="gender" name="gender" class="form-select">
                    <option value="">Any</option>
                    {% for g in genderOptions %}
                        <option value="{{ g }}" {% if g == selectedGender %}selected{% endif %}>{{ g }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Find Candidate</button>
            </div>
        </form>
    </div>

    {% if candidate and candidate.id %}
        <div class="alert alert-danger mt-2 mb-4 text-center">
            <h1>Smash or Pass</h1>
            <form method="get" action="{{ path('app_user_vote_vote') }}" class="row g-2 align-items-end">
                <input type="hidden" name="candidate_id" value="{{ candidate.id }}">
                <input type="hidden" name="category" value="{{ selectedCategory }}">
                <input type="hidden" name="gender" value="{{ selectedGender }}">
                <div>
                    <button type="submit" id="smash_1" name="smash" class="btn btn-lg btn-success" value="1">Smash</button>
                    <button type="submit" id="smash_0" name="smash" class="btn btn-lg btn-danger"value="0">Pass</button>
                </div>
            </form>
        </div>
    {% endif %}

    {% if candidate %}
        <div class="row mx-1">
            <div class="col-md-6 text-center">
                {% if candidate and candidate.id %}
                    <form method="post" action="{{ path('app_candidate_img_search', {'id': candidate.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('img-search' ~ candidate.id) }}">
                        <button class="btn btn-sm btn-primary" type="submit">Find new Picture</button>
                    </form>
                {% endif %}

                {% if candidate.imgurl %}
                    <img src="{{ candidate.imgurl }}" alt="Candidate image" class="img-fluid img-thumbnail mt-2" style="max-height:600px;">
                {% endif %}
            </div>
            <div class="col-md-6">
                {% if candidate and candidate.id %}
                    <table class="table table-bordered">
                        <tbody>
                            <tr>
                                <th class="text-end bg-secondary">Id</th>
                                <td>{{ candidate.id }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Name</th>
                                <td>{{ candidate.Name }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Bio</th>
                                <td>{{ candidate.Bio }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Birthdate</th>
                                <td>{{ candidate.Birthdate ? candidate.Birthdate|date('Y-m-d') : '' }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Height</th>
                                <td>{{ candidate.Height }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Weight</th>
                                <td>{{ candidate.Weight }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Home Town</th>
                                <td>{{ candidate.HomeTown }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Married</th>
                                <td>{{ candidate.Married ? 'Yes' : 'No' }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Income</th>
                                <td>{{ candidate.Income }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Political Affiliation</th>
                                <td>{{ candidate.PoliticalAffiliation }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Interests</th>
                                <td>{{ candidate.Interests }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Lifestyle</th>
                                <td>{{ candidate.Lifestyle }}</td>
                            </tr>
                            <tr>
                                <th class="text-end bg-secondary">Additional Information</th>
                                <td>{{ candidate.AdditionalInformation }}</td>
                            </tr>
                        </tbody>
                    </table>
                {% else %}
                    <div class="alert alert-warning">No Babes found that in Category ( {{selectedCategory}} ) that are {{selectedGender}}</div>
                {% endif %}
            </div>
        </div>

        {% if candidate and candidate.id %}
            <div class="alert alert-danger mt-2 mb-4 text-center">
                <h1>Smash or Pass</h1>
                <form method="get" action="{{ path('app_user_vote_vote') }}" class="row g-2 align-items-end">
                    <input type="hidden" name="candidate_id" value="{{ candidate.id }}">
                    <div>
                        <button type="submit" id="smash_1" name="smash" class="btn btn-lg btn-success" value="1">Smash</button>
                        <button type="submit" id="smash_0" name="smash" class="btn btn-lg btn-danger" value="0">Pass</button>
                    </div>
                </form>
            </div>
        {% endif %}

    {% else %}
        <div class="alert alert-warning">No Babes found that in Category ( {{selectedCategory}} ) that are {{selectedGender}}</div>
    {% endif %}

{% endblock %}
